@page "/login"
@inject ILocalStorageService LocalStorageService
@inject NavigationManager _NavigationManager
@inject AuthenticationStateProvider Provider

@if (!string.IsNullOrWhiteSpace(userName))
{
    <span>Добро пожаловать: <b>@userName</b></span>
}
else
{
    <div class="row">
        <div class="cl-md-6 offset-md-3">
            <h1>Внести данные</h1>
            <EditForm Model="@LoginData" OnValidSubmit="LoginAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <label for="username">Имя пользователя</label>
                <InputText id="username" @bind-Value="@LoginData.UserName" class="form-control" style="width:300px;"></InputText>

                <label for="password">Пароль</label>
                <InputText type="password" id="password" @bind-Value="@LoginData.Password" class="form-control" style="width:300px;"></InputText>

                <p class="my-4">
                    <button type="submit" class="btn btn-primary">Войти</button>
                </p>
            </EditForm>
        </div>
    </div>
}


@code {
    public LoginViewModel LoginData { get; set; } = new LoginViewModel();
    public string userName = string.Empty; //Будем в ней хранить имя пользователя.

    protected async Task LoginAsync()
    {
        //Здесь требуется организовать проверку существования пользователя
        //в БД. Сделаем допущение, что любые внесенные данные валидны
        //Не сохраняем пароль в хранилище браузера
        var token = new SequrityToken()
        {
            UserName = LoginData.UserName,
            ExpiretAt = DateTime.UtcNow.AddDays(1)
        };
        await LocalStorageService.SetAcync(nameof(SequrityToken), token);
        _NavigationManager.NavigateTo("./", true);
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await Provider.GetAuthenticationStateAsync();
        userName = state.User?.Identity?.Name ?? string.Empty;
    }
}
